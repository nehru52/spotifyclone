# Vatican Audio Guide - Environment Variables
# Copy this file to .env and fill in your values

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Your Sanity project ID (find in sanity.io dashboard)
EXPO_PUBLIC_SANITY_PROJECT_ID=your-project-id

# Sanity dataset (usually 'production')
EXPO_PUBLIC_SANITY_DATASET=production

# ── Cloudflare R2 CDN ─────────────────────────────────────────────────────────
# Your R2 bucket public URL (e.g., https://your-bucket.r2.dev)
EXPO_PUBLIC_AUDIO_CDN_BASE_URL=https://your-r2-bucket.r2.dev

# ── Content Provider ──────────────────────────────────────────────────────────
# Which CMS to use: 'sanity' or 'payload'
EXPO_PUBLIC_CONTENT_PROVIDER=sanity

# ── Optional ──────────────────────────────────────────────────────────────────
# Mapbox for maps (optional)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# Brand/legal URLs (optional)
EXPO_PUBLIC_BRAND_DOMAIN=https://your-domain.com
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.com/privacy
EXPO_PUBLIC_TERMS_URL=https://your-domain.com/terms
EXPO_PUBLIC_SUPPORT_URL=https://your-domain.com/support
