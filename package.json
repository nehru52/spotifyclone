{
  "name": "vatican-audio-guide",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=20",
    "yarn": ">=1.22.17"
  },
  "scripts": {
    "reset-project": "node ./scripts/reset-project.js",
    "prepare": "husky install",
    "lint": "expo lint",
    "prettier:write": "prettier --write **/*.{ts,tsx,json,md}",
    "prettier:check": "prettier --check **/*.{ts,tsx,json,md}",
    "bump-to-support": "npx expo install --fix",
    "build:api-key:ios": "eas build -p ios --profile preview",
    "build:bundle:ios": "eas build -p ios",
    "build:api-key:android": "eas build -p android --profile preview",
    "build:bundle:android": "eas build -p android",
    "dev": "expo start --port 8080",
    "dev:android": "expo start --android --port 8081",
    "dev:ios": "expo start --ios",
    "dev:web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "structure:win": "cmd.exe /C \"tree /F\"",
    "structure:os": "tree -d ."
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.3",
    "@gorhom/bottom-sheet": "^4.6.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "4.5.2",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@shopify/react-native-skia": "1.2.3",
    "@supabase/supabase-js": "^2.105.3",
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "axios": "^1.7.7",
    "expo": "~51.0.39",
    "expo-asset": "~10.0.10",
    "expo-audio": "^55.0.14",
    "expo-auth-session": "~5.5.2",
    "expo-av": "~14.0.7",
    "expo-blur": "~13.0.3",
    "expo-constants": "~16.0.2",
    "expo-file-system": "^17.0.1",
    "expo-font": "^12.0.10",
    "expo-image": "^1.13.0",
    "expo-linear-gradient": "^13.0.2",
    "expo-linking": "~6.3.1",
    "expo-location": "^17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.24",
    "expo-splash-screen": "~0.27.7",
    "expo-sqlite": "~14.0.6",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "^3.0.7",
    "expo-task-manager": "~11.8.2",
    "expo-web-browser": "^13.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-dominant-color": "^1.0.0",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-maps": "1.14.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-video": "^6.19.2",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.7.2",
    "@types/jest": "^29.5.13",
    "@types/react": "~18.2.79",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.1.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.4",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "~5.3.3"
  },
  "private": true
}
